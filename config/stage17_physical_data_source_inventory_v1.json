  "acquisitionPackages": [
    {
      "id": "package_A_official_office_request",
      "label": "遠賀川河川事務所への公式データ照会",
      "priority": 1,
      "status": "approval_required_before_external_contact",
      "requestedItems": [
        "Latest usable surveyed river cross sections and bed elevations for the approved model domain，including datum，survey date，and accuracy.",
        "Historical observed water level and discharge series，station metadata，rating-curve availability，quality flags，and vertical datums for lower Onga，Nishikawa，and any Magarigawa observations.",
        "Gatewise barrage operation records，upstream and downstream levels，effective gate geometry，invert elevations，and validated discharge coefficients.",
        "Fishway geometry，invert elevations，operation records，and discharge or head-discharge information.",
        "Existing ADCP or current-meter surveys near the confluences，barrage，fishway，and lower open boundary."
      ]
    },
    {
      "id": "package_B_public_database_retrieval",
      "label": "公開水文データベースの機械取得とstation metadata監査",
      "priority": 2,
      "status": "can_proceed_without_physical_model_approval",
      "requestedItems": [
        "Retrieve station metadata and available historical observed series for candidate main-stem and Nishikawa stations.",
        "Determine whether each station provides discharge，water level only，or a rating relation.",
        "Record coordinates，datum，sampling interval，quality flags，missingness，and period coverage.",
        "Do not map a station to M，N，O，or G until hydraulic compatibility is reviewed."
      ]
    },
    {
      "id": "package_C_secondary_tide_reference",
      "label": "気象庁潮位の二次参照整備",
      "priority": 3,
      "status": "secondary_only",
      "requestedItems": [
        "Inventory nearby north-Kyushu tide stations and datum metadata.",
        "Keep astronomical prediction separate from observed river-mouth water level.",
        "Use only for phase，datum，or plausibility comparison after an observed M-boundary source is selected."
      ]
    }
  ],
  "nextDecision": {
    "id": "stage17_data_acquisition_route",
    "status": "pending",
    "question": "Should the project pursue an official data request to the Onga River Office in parallel with public-database retrieval，or restrict the next stage to public data only?",
    "options": [
      {
        "id": "A_official_request_plus_public_retrieval",
        "recommended": true,
        "consequence": "Highest likelihood of obtaining bathymetry，vertical datum，gate operation，fishway hydraulics，and velocity observations required for defensible physical Validation."
      },
      {
        "id": "B_public_data_only",
        "recommended": false,
        "consequence": "Historical water-level data may be obtainable，but bathymetry，structure parameters，and Magarigawa or velocity observations may remain unresolved；physical Validation will remain blocked if authoritative data are absent."
      },
      {
        "id": "C_synthetic_verification_only",
        "recommended": false,
        "consequence": "No external data acquisition；continue numerical Verification without claiming real-flow prediction."
